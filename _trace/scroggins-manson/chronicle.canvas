	"nodes":[
		{"id":"process-group-demo","type":"group","x":-1760,"y":-2860,"width":14840,"height":3960,"label":"PROVENANCE / CHASE — process, alternates, prompts, feedback, dead ends, discoveries"},
		{"id":"conv-free-group","type":"group","x":19700,"y":-3050,"width":2620,"height":2160,"label":"CONVERSATION — free / self-inhabited / untenanted — P3 canon (2026-05-04)"},
		{"id":"b8c112016cbbd721","type":"group","x":6940,"y":-1433,"width":2220,"height":1576,"label":"REVISITING PAGES - i  worked from page 4 to page 5 to page 3 to page 2  here. Things became more clear/specific in that order"},
		{"id":"post-mike-feedback-group","type":"group","x":8800,"y":-2880,"width":2560,"height":1000,"label":"PAGE 3 — after Michael's feedback (2026-04-30)"},
