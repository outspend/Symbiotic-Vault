	"nodes":[
		{"id":"b8c112016cbbd721","type":"group","x":6940,"y":-1433,"width":2220,"height":1576,"label":"REVISITING PAGES - i  worked from page 4 to page 5 to page 3 to page 2  here. Things became more clear/specific in that order"},
		{"id":"47e9a12355c6cf8d","type":"group","x":6329,"y":-1433,"width":551,"height":1577,"label":"5 page comic first/solo pass"},
		{"id":"49d5ae837558b7de","type":"file","file":"_trace/_assets/B4634DEE-ED82-443C-A7EF-7ECB2420DDED_1_105_c.jpeg","x":2777,"y":-960,"width":283,"height":400},
